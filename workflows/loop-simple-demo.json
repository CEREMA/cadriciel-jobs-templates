{
  "id": "loop-simple-demo",
  "name": "Loop Simple Demo",
  "description": "Simple loop test - iterate over input array and echo each item",
  "version": "1.0.0",
  "tags": ["demo", "loop"],
  "variables": {},
  "input": [
    {
      "key": "items",
      "type": "array",
      "description": "Array of items to process",
      "example": ["apple", "banana", "cherry"]
    }
  ],
  "stages": [
    {
      "name": "Trigger",
      "type": "trigger",
      "isTrigger": true,
      "triggerType": "manual",
      "x": 100,
      "y": 200
    },
    {
      "name": "foreach-item",
      "isLoop": true,
      "source": "input.items",
      "mode": "parallel",
      "concurrency": 3,
      "x": 300,
      "y": 200
    },
    {
      "name": "echo-item",
      "image": "alpine:latest",
      "command": ["sh", "-c", "echo \"Processing item #{{loop.index}}: {{loop.item}}\" && echo \"{{loop.item}}\" > /data/result-{{loop.index}}.txt"],
      "produces": [
        {
          "key": "result",
          "type": "file",
          "path": "/data/result-{{loop.index}}.txt"
        }
      ],
      "timeout": 30,
      "x": 300,
      "y": 350
    },
    {
      "name": "Output",
      "type": "output",
      "isOutput": true,
      "x": 500,
      "y": 200
    }
  ],
  "edges": [
    { "source": "Trigger", "target": "foreach-item" },
    { "source": "foreach-item", "target": "echo-item", "sourcePort": "loop-body" },
    { "source": "foreach-item", "target": "Output", "sourcePort": "loop-done" }
  ]
}

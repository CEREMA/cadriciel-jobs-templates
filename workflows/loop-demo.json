{
  "id": "loop-demo",
  "name": "Loop Demo - Image Resizer",
  "description": "Demonstrates loop functionality by resizing multiple images in parallel",
  "version": "1.0.0",
  "tags": ["demo", "loop", "images"],
  "variables": {
    "outputWidth": 400,
    "outputHeight": 400,
    "outputFormat": "jpg"
  },
  "input": [
    {
      "key": "images",
      "type": "array",
      "description": "Array of image URLs to process",
      "example": [
        "https://picsum.photos/800/600",
        "https://picsum.photos/1200/900",
        "https://picsum.photos/640/480"
      ]
    }
  ],
  "stages": [
    {
      "name": "trigger",
      "isTrigger": true,
      "triggerType": "manual",
      "x": 100,
      "y": 200
    },
    {
      "name": "process-images",
      "isLoop": true,
      "source": "input.images",
      "mode": "parallel",
      "concurrency": 3,
      "x": 300,
      "y": 200
    },
    {
      "name": "resize-image",
      "image": "jrottenberg/ffmpeg:5-alpine",
      "command": ["sh", "-c", "apk add --no-cache imagemagick curl >/dev/null 2>&1 && curl -sL \"{{loop.item}}\" -o /tmp/input.jpg && convert /tmp/input.jpg -resize {{vars.outputWidth}}x{{vars.outputHeight}} /data/resized-{{loop.index}}.jpg && echo \"Resized image {{loop.index}}\""],
      "produces": [
        {
          "key": "resized",
          "type": "file",
          "path": "/data/resized-{{loop.index}}.jpg"
        }
      ],
      "timeout": 120,
      "x": 300,
      "y": 350
    },
    {
      "name": "output",
      "isOutput": true,
      "x": 550,
      "y": 200
    }
  ],
  "edges": [
    { "source": "trigger", "target": "process-images" },
    { "source": "process-images", "target": "resize-image", "sourcePort": "loop-body" },
    { "source": "process-images", "target": "output", "sourcePort": "loop-done" }
  ]
}
